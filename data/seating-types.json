        { "field": "base_type", "type": "enum", "detectability": "yes", "allowed_values": ["5-star with casters", "5-star with glides", "Sled base", "4-leg"], "groups": [["5-star with casters", "5-star with glides"]], "priority": "low" },
        { "field": "base_finish", "type": "enum", "detectability": "yes", "allowed_values": ["Black", "White", "Polished aluminum", "Painted color", "Natural wood"], "groups": [["Black", "White", "Polished aluminum", "Painted color"]], "priority": "low" },
        { "field": "frame", "type": "enum", "detectability": "yes", "allowed_values": ["Plastic", "Aluminum", "Metal"] },
        { "field": "seat_upholstery", "type": "enum", "detectability": "yes", "allowed_values": ["Fabric", "Leather", "Mesh / net"], "groups": [["Fabric", "Leather"]] },
        { "field": "design_register", "type": "enum", "detectability": "yes", "allowed_values": ["Minimal", "Organic", "Industrial", "Traditional", "Sculptural", "Utilitarian"] }
      ]
