    "lounge_chair": {
      "label": "Lounge Chair",
      "fields": [
        { "field": "seat_height_type", "type": "enum", "detectability": "no", "allowed_values": ["Fixed height", "Adjustable height"] },
        { "field": "swivel_mechanism", "type": "enum", "detectability": "no", "allowed_values": ["Fixed / no swivel", "Swivel", "Tilt-swivel", "Rocking"] },
        { "field": "arm_configuration", "type": "enum", "detectability": "yes", "allowed_values": ["Armless", "One arm", "Two arms", "Integrated / sculpted"], "priority": "essential" },
        {
          "field": "body_construction",
          "type": "enum",
          "detectability": "yes",
          "allowed_values": ["Upholstered", "Molded plastic shell", "Molded plywood shell", "Suspended / sling", "Panel / privacy enclosure"],
          "value_definitions": {
            "Upholstered": "any upholstered lounge chair body, including both continuous shell forms and traditional frame-and-cushion constructions",
            "Molded plastic shell": "hard plastic one-piece structural form is the visible seat and back surface",
            "Molded plywood shell": "structural bent or molded plywood; wood grain is visible as the structural surface, not just a veneer overlay",
            "Suspended / sling": "material is tensioned between a visible frame; seat and back hang rather than rest on a surface",
            "Panel / privacy enclosure": "high side panels form a three-sided or four-sided enclosure, rising above shoulder or head level"
          },
          "priority": "essential"
        },
        { "field": "base_finish", "type": "enum", "detectability": "yes", "allowed_values": ["Black", "Polished aluminum", "Wood", "Painted / powder coat"], "groups": [["Black", "Polished aluminum", "Painted / powder coat"]], "priority": "low" },
        { "field": "base_type", "type": "enum", "detectability": "yes", "allowed_values": ["4-leg", "Sled", "Pedestal", "Square plate / plinth", "Integrated base", "Casters"], "groups": [["4-leg", "Sled", "Pedestal", "Square plate / plinth", "Casters"]], "priority": "essential" },
        { "field": "seat_upholstery", "type": "enum", "detectability": "yes", "allowed_values": ["Fabric", "Leather", "None / unupholstered"], "groups": [["Fabric", "Leather"]] },
        { "field": "back_upholstery", "type": "enum", "detectability": "yes", "allowed_values": ["Matches seat", "Independent fabric", "Unupholstered shell"] },
        { "field": "back_height", "type": "enum", "detectability": "yes", "allowed_values": ["Low", "Mid", "High", "Full enclosure"], "groups": [["Low", "Mid"], ["Mid", "High"]], "priority": "essential" },
        { "field": "configuration", "type": "enum", "detectability": "yes", "allowed_values": ["Single seat", "Multi-seat / sofa", "Modular component", "Corner unit", "Ottoman"], "priority": "essential" },
        { "field": "design_register", "type": "enum", "detectability": "yes", "allowed_values": ["Minimal", "Organic", "Industrial", "Traditional", "Sculptural", "Utilitarian"] },
        { "field": "shape_character", "type": "enum", "detectability": "yes", "allowed_values": ["Soft / tapered", "Boxy"] },
        { "field": "plan_shape", "type": "enum", "detectability": "yes", "allowed_values": ["Round / semicircular", "Trapezoidal", "Reverse trapezoidal", "Square / rectangular", "N/A"] }
      ]
